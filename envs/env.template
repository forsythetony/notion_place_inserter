# This file defines which env variables are logged at startup. Keys are parsed
# dynamically (including commented optional entries like # KEY=). Sensitive
# values are masked with asterisks; the sensitive-key list lives in
# app/env_bootstrap.py (SENSITIVE_ENV_KEYS).
#
# App endpoint + auth secret
# Local example:
# BASE_URL=http://localhost:8000
# Hosted example:
# BASE_URL=https://your-app.example.com
BASE_URL=
# Auth secret for Authorization header (use SECRET=)
SECRET=

# Supabase (Phase 1 bootstrap) - REQUIRED for backend
# From Supabase Dashboard > Project Settings > General
SUPABASE_PROJECT_REF=  # Project reference ID (e.g. ngwcqykrmlwlythbkmwn)
SUPABASE_URL=  # API URL (e.g. https://<project-ref>.supabase.co) - REQUIRED
# From Supabase Dashboard > Project Settings > API > Publishable and secret API keys
SUPABASE_PUBLISHABLE_KEY=  # Publishable key (client-side; safe to expose)
SUPABASE_SECRET_KEY=  # Secret key (backend only; bypasses RLS; keep secret) - REQUIRED
# Legacy: anon/service_role keys still work; use Legacy tab if you prefer those names.
# Optional overrides (defaults shown):
# SUPABASE_QUEUE_NAME=locations_jobs
# SUPABASE_TABLE_PLATFORM_JOBS=platform_jobs
# SUPABASE_TABLE_PIPELINE_RUNS=pipeline_runs
# SUPABASE_TABLE_PIPELINE_RUN_EVENTS=pipeline_run_events

# Notion API
NOTION_API_KEY=  # Create at https://www.notion.so/my-integrations

# Anthropic API
ANTHROPIC_TOKEN=

# Google Places API
GOOGLE_PLACES_API_KEY=  # See README for setup instructions

# Freepik Icons API (optional; page icons prefer Freepik when set.
# In DRY_RUN mode, icon resolution falls back to emoji when Freepik is unavailable/no result.
# In non-dry-run mode, unavailable/no-result Freepik leaves page icon blank.)
# FREEPIK_API_KEY=  # Create at https://www.freepik.com/api

# Local testing: set to 1 to echo property payloads without creating Notion pages
# DRY_RUN=1

# Async locations: set to 0 to run pipeline synchronously (default 1 = async, immediate 200 accepted)
# LOCATIONS_ASYNC_ENABLED=1

# Google Places: set to 0 to skip the optional Place Details fetch (reduces API usage;
# Notes descriptions may be less rich when search lacks generativeSummary/editorialSummary)
# GOOGLE_PLACE_DETAILS_FETCH=0

# Locations relation: cache TTL (seconds; default 1800 = 30 min)
# LOCATIONS_CACHE_TTL_SECONDS=1800

# Locations relation: minimum confidence for matching existing location (0–1; default 0.85)
# LOCATION_MATCH_MIN_CONFIDENCE=0.85

# Locations relation: set to 1 to require relation (propagate failure); default 0 = skip on error
# LOCATION_RELATION_REQUIRED=0

# Logging (optional; defaults suit resource-constrained environments)
# LOG_LEVEL=INFO
# LOG_FILE_PATH=logs/app.log
# LOG_FILE_ROTATION=10 MB
# LOG_FILE_RETENTION=3

# WhatsApp run-status notifications (optional; when async enabled, sends success/failure to recipient)
# Requires Twilio account and WhatsApp sandbox.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# WHATSAPP_STATUS_RECIPIENT_DEFAULT=whatsapp:+1XXXXXXXXXX
# WHATSAPP_STATUS_ENABLED=1
# WHATSAPP_STATUS_MAX_ERROR_CHARS=300
